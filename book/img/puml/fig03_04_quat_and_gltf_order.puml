@startuml
title クォータニオンと glTF の並び順

left to right direction
'top to bottom direction
skinparam backgroundColor white
skinparam shadowing true
skinparam dpi 150
skinparam defaultFontName Yu Gothic UI
skinparam defaultFontSize 18
skinparam rectangle {
  RoundCorner 24
  BorderColor black
  BackgroundColor #f7fbff
  FontColor black
}
skinparam ArrowColor black
skinparam ranksep 20
skinparam nodesep 20

rectangle "webg Quat\n[w, x, y, z]" as WebgQuat
rectangle "glTF / GLB\n[x, y, z, w]" as GltfQuat
rectangle "読み込み時に並び替えて行列や\nランタイムの姿勢へ変換" as Convert

WebgQuat --> Convert
GltfQuat --> WebgQuat : 順序が違う
GltfQuat .down.> Convert : loader が変換
@enduml
