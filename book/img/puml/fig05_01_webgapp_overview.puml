@startuml
title WebgApp 全体構成図

top to bottom direction
'left to right direction
skinparam backgroundColor white
skinparam shadowing true
skinparam dpi 150
skinparam defaultFontName Yu Gothic UI
skinparam defaultFontSize 18
skinparam rectangle {
  RoundCorner 24
  BorderColor black
  BackgroundColor #f7fbff
  FontColor black
}
skinparam ArrowColor black
skinparam ranksep 20
skinparam nodesep 20

rectangle "new WebgApp(options)" as NewApp
rectangle "await app.init()" as InitApp
rectangle "app.start ({onUpdate,onAfterHud})" as StartApp

rectangle "Screen" as Screen
rectangle "Space" as Space
rectangle "camera rig" as CameraRig
rectangle "InputController" as InputController
rectangle "HUD / Message" as HudOverlay
rectangle "Diagnostics" as Diagnostics
rectangle "Loader" as LoaderFacade
rectangle "update" as UpdateHandlers
rectangle "draw 3D scene" as DrawScene
rectangle "draw HUD" as DrawHud

NewApp -down-> InitApp
InitApp --> StartApp

StartApp --> Screen
StartApp --> Space
StartApp --> CameraRig
StartApp --> InputController
StartApp --> HudOverlay
StartApp --> Diagnostics
StartApp --> LoaderFacade

Screen ..> UpdateHandlers
Space --> DrawScene
HudOverlay --> DrawHud
LoaderFacade ..> StartApp
@enduml
