@startuml
title ポストプロセス描画フロー図

left to right direction
skinparam backgroundColor white
skinparam shadowing true
skinparam dpi 150
skinparam defaultFontName Yu Gothic UI
skinparam defaultFontSize 18
skinparam rectangle {
  RoundCorner 24
  BorderColor black
  BackgroundColor #f7fbff
  FontColor black
}
skinparam ArrowColor black
skinparam ranksep 20
skinparam nodesep 20

rectangle "beginScene()" as BeginScene
rectangle "space.draw()" as SpaceDraw
rectangle "offscreen\ncolor + depth" as Offscreen
rectangle "Bloom / DOF /\nVignette" as PostFx
rectangle "render to\ncanvas" as RenderCanvas
rectangle "clearDepthBuffer()" as ClearDepth
rectangle "Message /\nHUD / overlay" as HudOverlay

BeginScene -down-> SpaceDraw
SpaceDraw --> Offscreen
Offscreen -down-> PostFx
PostFx --> RenderCanvas
ClearDepth -down-> HudOverlay
RenderCanvas --> HudOverlay

Offscreen -[hidden]down-> ClearDepth
PostFx -[hidden]down-> HudOverlay

note bottom of PostFx
ポストプロセス
end note

note top of Offscreen
シーンをいったん
テクスチャへ描く
end note

note bottom of RenderCanvas
表示
end note

note bottom of HudOverlay
文字は最後に重ねる
end note

@enduml
