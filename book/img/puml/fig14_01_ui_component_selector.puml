@startuml
title 表示用部品の選択

top to bottom direction
skinparam backgroundColor white
skinparam shadowing true
skinparam dpi 150
skinparam defaultFontName Yu Gothic UI
skinparam defaultFontSize 18
skinparam rectangle {
  RoundCorner 24
  BorderColor black
  BackgroundColor #f7fbff
  FontColor black
}
skinparam ArrowColor black
skinparam ranksep 20
skinparam nodesep 20

rectangle "今ほしい表示は何か" as Root

rectangle "短い情報を\n常時見せたい" as ShortInfo
rectangle "長文を\n読ませたい" as LongText
rectangle "操作ボタンを\n出したい" as Buttons
rectangle "診断情報を\n共有したい" as Diagnostics

rectangle "Text / Message" as TextMessage
rectangle "FixedFormatPanel /\nDialogueOverlay" as FixedDialogue
rectangle "UIPanel / Touch" as UIPanelTouch
rectangle "Diagnostics /\nDebugDock" as DebugDock

Root --> ShortInfo
Root --> LongText
Root --> Buttons
Root --> Diagnostics

ShortInfo --> TextMessage
LongText --> FixedDialogue
Buttons --> UIPanelTouch
Diagnostics --> DebugDock

ShortInfo -[hidden]right-> LongText
LongText -[hidden]right-> Buttons
Buttons -[hidden]right-> Diagnostics
TextMessage -[hidden]right-> FixedDialogue
FixedDialogue -[hidden]right-> UIPanelTouch
UIPanelTouch -[hidden]right-> DebugDock
@enduml
